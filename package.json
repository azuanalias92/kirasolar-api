{
  "name": "kirasolar-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local src/index.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply kirasolar-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply kirasolar-db --remote"
  },
  "dependencies": {
    "hono": "^4.5.0",
    "jose": "^6.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.1",
    "typescript": "^5.6.3",
    "wrangler": "^4.20.0"
  }
}
